rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- HELPERS ---------- */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function hasRole(roleName) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && get(/databases/$(database)/documents/users/$(uid())).data.role == roleName
        && get(/databases/$(database)/documents/users/$(uid())).data.isActive == true;
    }

    function isAdmin() {
      return hasRole("ADMIN");
    }

    function isEngineer() {
      return hasRole("ENGINEER");
    }

    function isAccountant() {
      return hasRole("ACCOUNTANT");
    }

    function assignedEngineerForSiteId(siteId) {
      return exists(/databases/$(database)/documents/sites/$(siteId))
        && get(/databases/$(database)/documents/sites/$(siteId)).data.assignedEngineerId == uid();
    }

    function canReadSite(siteId) {
      return isAdmin()
        || isAccountant()
        || (isEngineer() && assignedEngineerForSiteId(siteId));
    }

    function canReadRpInsightResource() {
      return isAdmin()
        || isAccountant()
        || (
          isEngineer()
          && ("siteId" in resource.data)
          && assignedEngineerForSiteId(resource.data.siteId)
        );
    }

    /* ---------- USERS ---------- */
    match /users/{userId} {

      // IMPORTANT: allow user to read their own document (fix login circular dependency)
      allow read: if signedIn() && userId == uid();

      // Admin full access
      allow read, write: if isAdmin();

      // Push-token update path for any authenticated user (self only)
      allow update: if signedIn()
        && userId == uid()
        && request.resource.data.role == resource.data.role
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "pushToken",
          "pushTokens",
          "pushPermission",
          "pushTokenUpdatedAt",
          "updatedAt"
        ]);

      allow create: if signedIn() && userId == uid();

      allow delete: if false;
    }

    /* ---------- SITES ---------- */
    match /sites/{siteId} {
      allow read, write: if isAdmin();

      allow read: if isEngineer()
        && resource.data.assignedEngineerId == uid();

      allow read, update: if isAccountant();

      allow create, delete: if false;
    }

    /* ---------- STAGE WORKFLOW ---------- */
    match /sites/{siteId}/executionStages/{stageId} {

      function assignedEngineerForSite() {
        return exists(/databases/$(database)/documents/sites/$(siteId))
          && get(/databases/$(database)/documents/sites/$(siteId)).data.assignedEngineerId == uid();
      }

      allow read, write: if isAdmin();

      allow read: if isAccountant();

      allow read: if isEngineer() && assignedEngineerForSite();

      allow update: if isEngineer()
        && assignedEngineerForSite()
        && request.resource.data.stageName == resource.data.stageName
        && request.resource.data.phaseName == resource.data.phaseName
        && request.resource.data.orderIndex == resource.data.orderIndex
        && request.resource.data.assignedEngineerId == resource.data.assignedEngineerId
        && request.resource.data.assignedEngineerName == resource.data.assignedEngineerName
        && request.resource.data.dependencyRule == resource.data.dependencyRule
        && request.resource.data.allowParallelExecution == resource.data.allowParallelExecution
        && request.resource.data.overrideUnlocked == resource.data.overrideUnlocked
        && request.resource.data.criticalStage == resource.data.criticalStage
        && request.resource.data.estimatedStageCost == resource.data.estimatedStageCost
        && request.resource.data.actualStageCost == resource.data.actualStageCost
        && request.resource.data.variance == resource.data.variance
        && request.resource.data.suggestedMaterials == resource.data.suggestedMaterials;

      allow create, delete: if false;
    }

    /* ---------- SITE CONTACT DIRECTORY ---------- */
    match /sites/{siteId}/contacts/{contactId} {

      function assignedEngineerForSiteContacts() {
        return exists(/databases/$(database)/documents/sites/$(siteId))
          && get(/databases/$(database)/documents/sites/$(siteId)).data.assignedEngineerId == uid();
      }

      allow read: if isAdmin()
        || isAccountant()
        || (isEngineer() && assignedEngineerForSiteContacts());

      allow create, update, delete: if isAdmin()
        || (isEngineer() && assignedEngineerForSiteContacts());
    }

    /* ---------- RP INSIGHT: AI DRAWING METADATA ---------- */
    match /rpInsightFiles/{fileId} {
      // Client apps may read file status/metadata only for sites they can access.
      // Uploads, parsing status, embeddings and source chunks must be written by the backend.
      allow read: if canReadRpInsightResource();
      allow create, update, delete: if false;
    }

    match /rpInsightChats/{chatId} {
      // Optional backend-written audit/chat history. Do not store raw CAD binaries or vectors here.
      allow read: if canReadRpInsightResource();
      allow create, update, delete: if false;
    }

    match /sites/{siteId}/rpInsightFiles/{fileId} {
      // Optional site-scoped mirror for frontend status screens.
      allow read: if canReadSite(siteId);
      allow create, update, delete: if false;
    }

    match /sites/{siteId}/rpInsightChats/{chatId} {
      // Optional site-scoped mirror for frontend chat history.
      allow read: if canReadSite(siteId);
      allow create, update, delete: if false;
    }

    /* ---------- TASKS ---------- */
    match /tasks/{taskId} {

      function oldPendingHistory() {
        return ("pendingHistory" in resource.data && resource.data.pendingHistory is list)
          ? resource.data.pendingHistory
          : [];
      }

      function newPendingHistory() {
        return ("pendingHistory" in request.resource.data && request.resource.data.pendingHistory is list)
          ? request.resource.data.pendingHistory
          : [];
      }

      function pendingHistoryChanged() {
        return newPendingHistory() != oldPendingHistory();
      }

      function validPendingEntry(entry) {
        return entry is map
          && entry.keys().hasOnly([
            "reasonType",
            "note",
            "loggedByName",
            "loggedByUid",
            "loggedAt"
          ])
          && entry.reasonType is string
          && entry.note is string
          && entry.loggedByName is string
          && entry.loggedByUid is string
          && entry.loggedAt is timestamp;
      }

      function pendingHistoryAppendOnly() {
        return !pendingHistoryChanged()
          || (
            newPendingHistory().size() == oldPendingHistory().size() + 1
            && validPendingEntry(newPendingHistory()[newPendingHistory().size() - 1])
            && newPendingHistory()[newPendingHistory().size() - 1].loggedByUid == uid()
          );
      }

      function validLastPendingReasonAt() {
        return !("lastPendingReasonAt" in request.resource.data)
          || request.resource.data.lastPendingReasonAt is timestamp;
      }

      function pendingReasonMetaConsistent() {
        return !pendingHistoryChanged()
          || (
            "lastPendingReasonAt" in request.resource.data
            && request.resource.data.lastPendingReasonAt is timestamp
          );
      }

      allow read, write: if isAdmin();

      allow read: if isAccountant();

      allow read: if isEngineer()
        && resource.data.assignedEngineerId == uid();

      allow create: if isEngineer()
        && request.resource.data.assignedEngineerId == uid()
        && request.resource.data.status == "PENDING"
        && request.resource.data.weekKey is string
        && request.resource.data.siteId is string;

      allow update: if isEngineer()
        && resource.data.assignedEngineerId == uid()
        && request.resource.data.assignedEngineerId == resource.data.assignedEngineerId
        && request.resource.data.siteId == resource.data.siteId
        && request.resource.data.weekKey == resource.data.weekKey
        && pendingHistoryAppendOnly()
        && validLastPendingReasonAt()
        && pendingReasonMetaConsistent();

      allow delete: if false;
    }

    /* ---------- ACCOUNTING: LABOUR ---------- */
    match /labour_entries/{entryId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: MATERIAL ---------- */
    match /material_entries/{entryId} {
      allow read, write: if isAdmin();
      allow read, write: if isAccountant();
    }

    /* ---------- ACCOUNTING: DEALER PAYMENTS ---------- */
    match /dealer_payments/{paymentId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: ATTENDANCE STAFF ---------- */
    match /attendance_staff/{personId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: ATTENDANCE RECORDS ---------- */
    match /attendance_records/{recordId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- REPORT SNAPSHOTS ---------- */
    match /reportSnapshots/{weekKey} {
      allow read, create, update, delete: if isAdmin();
    }

    /* ---------- DEALERS ---------- */
    match /dealers/{dealerId} {
      allow read, write: if isAdmin() || isAccountant();
    }

    /* ---------- PROJECT ESTIMATES ---------- */
    match /projectEstimates/{estimateId} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
