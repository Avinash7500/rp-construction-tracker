rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- HELPERS ---------- */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function hasRole(roleName) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && get(/databases/$(database)/documents/users/$(uid())).data.role == roleName
        && get(/databases/$(database)/documents/users/$(uid())).data.isActive == true;
    }

    function isAdmin() {
      return hasRole("ADMIN");
    }

    function isEngineer() {
      return hasRole("ENGINEER");
    }

    function isAccountant() {
      return hasRole("ACCOUNTANT");
    }

    /* ---------- USERS ---------- */
    match /users/{userId} {
      allow read, write: if isAdmin();
      allow read: if (isEngineer() || isAccountant()) && userId == uid();
      allow update: if isEngineer()
        && userId == uid()
        && request.resource.data.role == resource.data.role
        && request.resource.data.isActive == resource.data.isActive;
      allow create: if signedIn() && userId == uid();
      allow delete: if false;
    }

    /* ---------- SITES ---------- */
    match /sites/{siteId} {
      allow read, write: if isAdmin();
      allow read: if isEngineer() && resource.data.assignedEngineerId == uid();
      allow read, update: if isAccountant();
      allow create, delete: if false;
    }

    /* ---------- STAGE WORKFLOW (SITE SUBCOLLECTION) ---------- */
    match /sites/{siteId}/executionStages/{stageId} {
      function assignedEngineerForSite() {
        return exists(/databases/$(database)/documents/sites/$(siteId))
          && get(/databases/$(database)/documents/sites/$(siteId)).data.assignedEngineerId == uid();
      }

      // Admin has complete control of workflow orchestration.
      allow read, write: if isAdmin();

      // Accountant can view progress for monitoring/reporting.
      allow read: if isAccountant();

      // Engineer can only access workflow of assigned site.
      allow read: if isEngineer() && assignedEngineerForSite();

      // Engineer can update operational fields only (task updates, progress, delay logs).
      allow update: if isEngineer()
        && assignedEngineerForSite()
        && request.resource.data.stageName == resource.data.stageName
        && request.resource.data.phaseName == resource.data.phaseName
        && request.resource.data.orderIndex == resource.data.orderIndex
        && request.resource.data.assignedEngineerId == resource.data.assignedEngineerId
        && request.resource.data.assignedEngineerName == resource.data.assignedEngineerName
        && request.resource.data.dependencyRule == resource.data.dependencyRule
        && request.resource.data.allowParallelExecution == resource.data.allowParallelExecution
        && request.resource.data.overrideUnlocked == resource.data.overrideUnlocked
        && request.resource.data.criticalStage == resource.data.criticalStage
        && request.resource.data.estimatedStageCost == resource.data.estimatedStageCost
        && request.resource.data.actualStageCost == resource.data.actualStageCost
        && request.resource.data.variance == resource.data.variance
        && request.resource.data.suggestedMaterials == resource.data.suggestedMaterials;

      // Only admin can create/delete/reorder stage documents.
      allow create, delete: if false;
    }

    /* ---------- SITE CONTACT DIRECTORY ---------- */
    match /sites/{siteId}/contacts/{contactId} {
      function assignedEngineerForSiteContacts() {
        return exists(/databases/$(database)/documents/sites/$(siteId))
          && get(/databases/$(database)/documents/sites/$(siteId)).data.assignedEngineerId == uid();
      }

      allow read: if isAdmin()
        || isAccountant()
        || (isEngineer() && assignedEngineerForSiteContacts());

      allow create, update, delete: if isAdmin()
        || (isEngineer() && assignedEngineerForSiteContacts());
    }

    /* ---------- TASKS ---------- */
    match /tasks/{taskId} {
      allow read, write: if isAdmin();

      // Engineer Reports query support:
      // where("assignedEngineerId", "==", uid()) + orderBy("createdAt")
      allow read: if isAccountant()
        || (isEngineer() && resource.data.assignedEngineerId == uid());

      // Engineer can create own pending tasks (including carry-forward generated entries).
      allow create: if isEngineer()
        && request.resource.data.assignedEngineerId == uid()
        && request.resource.data.status == "PENDING"
        && request.resource.data.weekKey is string
        && request.resource.data.siteId is string
        && (
          !("createdBy" in request.resource.data)
          || request.resource.data.createdBy == "ENGINEER"
          || request.resource.data.createdBy == "ADMIN"
        );

      // Engineer can update only own tasks; lock ownership and task identity fields.
      allow update: if isEngineer()
        && resource.data.assignedEngineerId == uid()
        && request.resource.data.assignedEngineerId == resource.data.assignedEngineerId
        && request.resource.data.siteId == resource.data.siteId
        && request.resource.data.weekKey == resource.data.weekKey;

      allow delete: if false;
    }

    /* ---------- ACCOUNTING: LABOUR ENTRIES ---------- */
    match /labour_entries/{entryId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: MATERIAL ENTRIES ---------- */
    match /material_entries/{entryId} {
      allow read, write: if isAdmin();
      allow read, write: if isAccountant();
    }

    /* ---------- ACCOUNTING: DEALER PAYMENTS ---------- */
    match /dealer_payments/{paymentId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: ATTENDANCE STAFF ---------- */
    match /attendance_staff/{personId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- ACCOUNTING: ATTENDANCE RECORDS ---------- */
    match /attendance_records/{recordId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isAccountant();
      allow delete: if false;
    }

    /* ---------- REPORT SNAPSHOTS ---------- */
    match /reportSnapshots/{weekKey} {
      allow read, create, update, delete: if isAdmin();
    }

    /* ---------- DEALER MASTER REGISTRY ---------- */
    match /dealers/{dealerId} {
      allow read, write: if isAdmin() || isAccountant();
    }

    /* ---------- PROJECT ESTIMATES ---------- */
    match /projectEstimates/{estimateId} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
